#include <stdio.h>
#include <stdlib.h>
#include <boost/test/unit_test.hpp>
#include "gate-utils.hpp"
#include "Vgate_@GATE_NAME@_@GATE_WAY@_@GATE_WIRE@.h"
#include "verilated_vcd_c.h"

#define SIZE (@GATE_WAY@ * @GATE_WIRE@)
#define MAX_MASK (1 << (SIZE-1)) - 1

BOOST_AUTO_TEST_SUITE (Vgate_@GATE_NAME@_@GATE_WAY@_@GATE_WIRE@_tests)

BOOST_AUTO_TEST_CASE (validator_gate_@GATE_NAME@_@GATE_WAY@_@GATE_WIRE@)
{
  VerilatedContext* contextp = new VerilatedContext;
  VerilatedVcdC* tfp = new VerilatedVcdC;
  Vgate_@GATE_NAME@_@GATE_WAY@_@GATE_WIRE@ *gate = new Vgate_@GATE_NAME@_@GATE_WAY@_@GATE_WIRE@{contextp};

  Verilated::traceEverOn(true);
  gate->trace(tfp, 99);
  tfp->open("build/signal/primitive/gate/signal_Vgate_@GATE_NAME@_@GATE_WAY@_@GATE_WIRE@.vcd");
  
  if (SIZE > 64)
    BOOST_FAIL("taille trop grande actuellement non gerer");

  for (unsigned cpt=0; cpt < 0xFFFFFF && cpt < 0xFFFF; cpt++)//max_mask
    {
      srand(cpt);
      unsigned long input = GET_BIT_RANGE(((unsigned long)rand() << 32) | rand(), SIZE, 0);

      gate->in = input;
      gate->eval();
      tfp->dump(contextp->time());
      contextp->timeInc(1);

      unsigned long result = (test_@GATE_NAME@(input, @GATE_WAY@, @GATE_WIRE@));
      if (gate->out != result)
	printf("@GATE_NAME@_@GATE_WAY@_@GATE_WIRE@ inputs = %x : gate->in = %x: out = %x : result = %x\n",
	       input, gate->in, gate->out, result);

      BOOST_REQUIRE_EQUAL(gate->out, result);
    }
  tfp->close();
  gate->final();
  contextp->statsPrintSummary();

  delete tfp;
  delete gate;
  delete contextp;
}

BOOST_AUTO_TEST_SUITE_END()
