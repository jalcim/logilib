#include <stdio.h>
#include <boost/test/unit_test.hpp>
#include "gate-utils.hpp"
#include "Vgate_@GATE_NAME@_@GATE_WAY@.h"

BOOST_AUTO_TEST_SUITE (Vgate_@GATE_NAME@_@GATE_WAY@_tests)

BOOST_AUTO_TEST_CASE (validator_lsb)
{
  int result;
    constexpr size_t inputs{1 << @GATE_WAY@};
    VerilatedContext* contextp = new VerilatedContext;
    contextp->debug(0);
    contextp->traceEverOn(true);
    Vgate_@GATE_NAME@_@GATE_WAY@ *gate = new Vgate_@GATE_NAME@_@GATE_WAY@{contextp};
    for (size_t input{0}; input < inputs; ++input)
    {
        gate->in = input;
        gate->eval();

	result = (test_lsb_@GATE_NAME@(input, @GATE_WAY@) & 1);
	if ((gate->out & 1) != result)
	  printf("@GATE_NAME@_@GATE_WAY@ inputs = %x : out = %x : ret = %x\n",
		 input, gate->out, result);
        BOOST_REQUIRE_EQUAL(gate->out & 1, result);
	contextp->timeInc(1);
    }
    contextp->statsPrintSummary();
    gate->final();
    delete gate;
    delete contextp;
}

